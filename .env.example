# ============================================================
# BURNOUTGUARD - Template Environment Variables
# Salin file ini menjadi .env.local dan isi dengan nilai yang sesuai.
# JANGAN pernah mengisi file ini dengan kredensial asli!
# ============================================================

# ----------------------------
# Supabase Configuration
# Dapatkan nilai ini dari: https://supabase.com/dashboard > Project Settings > API
# ----------------------------

# URL project Supabase Anda (contoh: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Anon/Public key Supabase (aman untuk digunakan di sisi client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role key Supabase (RAHASIA - hanya digunakan di sisi server)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ----------------------------
# Machine Learning API
# URL endpoint API prediksi burnout (dihosting di Hugging Face Spaces)
# ----------------------------

# Base URL untuk Burnout Prediction API
BURNOUT_API_URL=your_huggingface_spaces_api_url_here

# ----------------------------
# Site Configuration
# ----------------------------

# URL publik aplikasi (gunakan http://localhost:3000 untuk development)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
